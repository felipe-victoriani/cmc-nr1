        ".read": "auth != null && ($uid === auth.uid || root.child('users').child(auth.uid).child('tipo').val() === 'admin_master')",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('tipo').val() === 'admin_master' || $uid === auth.uid)"
      }
